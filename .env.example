# Control-plane API
PORT=3000
FORGELOOP_API_URL=http://localhost:3000

# Web client
VITE_FORGELOOP_API_URL=http://localhost:3000

# Durable local mode
FORGELOOP_DATABASE_URL=postgresql://forgeloop:forgeloop@localhost:5432/forgeloop

# Local repo binding and dogfood defaults
FORGELOOP_REPO_PATH=/absolute/path/to/forgeloop
FORGELOOP_REPO_ID=forgeloop
FORGELOOP_BASE_COMMIT_SHA=
FORGELOOP_DEFAULT_BRANCH=main

# Real local Codex dogfood is opt-in.
FORGELOOP_ENABLE_REAL_CODEX_DOGFOOD=0
FORGELOOP_LOCAL_CODEX_DOGFOOD_ALLOW_DIRTY=0

# Required when NODE_ENV=production and creating run event stream tokens.
FORGELOOP_DEV_AUTH_SECRET=replace-with-a-local-secret

# Durable dogfood helper.
FORGELOOP_DOGFOOD_START_POSTGRES=0
